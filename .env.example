# Render (long-running server) — set in Render dashboard
# NODE_ENV=production
# PORT is injected automatically by Render
# RUN_PAYMENT_WORKER=false   # use separate worker service; true for single-service deploy

PORT=4000
DATABASE_URL=postgresql://payroll:payroll@localhost:5432/payroll
CORS_ORIGIN=http://localhost:3000
DEFAULT_COMPANY_ID=a0000001-0000-4000-8000-000000000001

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
DEMO_2FA_CODE=123456
DEMO_PASSWORD=password123
SEED_ADMIN_EMAIL=admin@platform.com
SEED_ADMIN_PASSWORD=

# Resend (OTP + transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Instanvi Payroll <onboarding@yourdomain.com>
APP_PUBLIC_URL=http://localhost:3000

# Instanvi Integration Payments API
INSTANVI_PAYMENTS_BASE_URL=http://localhost:3001/api/integration/payments
# Optional platform fallback when a company has not saved its own key (app_… format)
INSTANVI_API_KEY=
INSTANVI_LOCATION_ID=

# Per-company Instanvi keys are encrypted at rest using JWT_SECRET (AES-256-GCM).
# Optional legacy fallback only if you previously used a separate encryption key:
# INTEGRATION_ENCRYPTION_KEY=
INSTANVI_CALLBACK_URL=http://localhost:4000/api/payments/mobile/webhook

# Redis (BullMQ payment queue)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Payment queue
PAYMENT_QUEUE_ATTEMPTS=3
PAYMENT_QUEUE_CONCURRENCY=5
RUN_PAYMENT_WORKER=true

# Cloudinary (KYC document uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_KYC_FOLDER=instanvi/kyc
