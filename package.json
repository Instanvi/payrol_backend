{
  "name": "payment-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "npm run build:app && npm run build:server && npm run build:worker && npm run build:migrate",
    "build:app": "esbuild src/app.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/app.js --packages=external",
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external",
    "build:worker": "esbuild src/worker.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/worker.js --packages=external",
    "build:migrate": "esbuild src/db/migrate.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/db/migrate.js --packages=external",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "worker:start": "node dist/worker.js",
    "db:migrate": "node dist/db/migrate.js",
    "db:migrate:dev": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate-timestamps": "tsx src/db/migrate-timestamps.ts",
    "db:migrate-charges": "tsx src/db/migrate-charges.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:reset": "tsx src/db/reset.ts && npm run db:setup"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.16.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "typescript": "^5"
  }
}
